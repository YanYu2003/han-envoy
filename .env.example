# ===================================================
# 《汉使》Han Envoy — 环境变量示例
# 使用前请复制为 .env 文件并填入真实值
# 警告：切勿将 .env 文件提交到版本控制
# ===================================================

# ---- AI 游玩模式 ----
# 可选值: presetOnly | mock | realAI
# presetOnly: 只保留预设选项，隐藏自由输入（演示/无 AI 模式）
# mock: 使用本地 MockAIProvider（开发默认，关键词匹配模拟）
# realAI: 通过后端代理调用真实大模型（需配置 VITE_AI_PROXY_URL）
VITE_AI_PLAY_MODE=mock

# ---- 后端代理 URL（仅 realAI 模式需要） ----
# 前端通过此地址请求自己的后端代理，
# 由代理转发到真实 AI Provider（如 OpenAI / DeepSeek / 腾讯混元）。
# 真实 API Key 仅存储在服务端环境变量中，不会暴露到前端。
VITE_AI_PROXY_URL=/api/ai

# ---- 【不推荐公开部署】直接 API 配置 ----
# 以下变量仅适合本地快速实验，不推荐在生产环境中使用。
# 正式部署时，真实 API Key 不应放在前端环境变量中。
# VITE_AI_API_KEY 在 Vite 中会打包进浏览器端代码，不可保密。

# AI 服务提供商 (可选: openai, tencent, deepseek, etc.)
VITE_AI_PROVIDER=

# AI API 请求地址
VITE_AI_API_BASE_URL=

# AI API 密钥 — 请勿写死在代码中；公开部署时勿使用
VITE_AI_API_KEY=

# ---- 游戏配置 ----
VITE_GAME_VERSION=0.1.0
