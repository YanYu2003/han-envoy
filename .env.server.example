# ===================================================
# 《汉使》Han Envoy — 服务端环境变量示例
# 使用前请复制为 .env.server 并填入真实值
# 警告：切勿将 .env.server 提交到版本控制
# ===================================================

# AI Provider 名称（仅用于日志显示）
AI_PROVIDER=openai-compatible

# API 基础地址（OpenAI-compatible Chat Completions 接口）
# DeepSeek: https://api.deepseek.com
# OpenAI:   https://api.openai.com/v1
AI_API_BASE_URL=https://api.deepseek.com

# AI API 密钥 — 请勿写死在代码中
# 此为服务端环境变量，不会暴露到前端
AI_API_KEY=

# 模型名称
# DeepSeek: deepseek-chat 或 deepseek-reasoner
# OpenAI:   gpt-4o-mini 或 gpt-4o
AI_MODEL=deepseek-chat

# 代理端口
AI_PROXY_PORT=8787

# CORS 允许的源（逗号分隔多个源）
AI_PROXY_ALLOWED_ORIGIN=http://localhost:3000
